# API 基础路径
VITE_API_BASE_URL=/api

# 腾讯云 IM 应用 ID
VITE_TCC_APP_ID=

# 允许的 Host 域名（开发环境）
VITE_ALLOWED_HOST=

# HTTPS 反向代理目标域名
VITE_PROXY_TARGET=

# 应用基础路径
VITE_PUBLIC_PATH=/

# 环境名称
VITE_ENV_NAME=development

# 应用预览模式
VITE_APP_PREVIEW=

# Tauri 开发主机
VITE_TAURI_DEV_HOST=

# Dev Server 主机地址
VITE_DEV_SERVER_HOST=0.0.0.0
